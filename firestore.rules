rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global helpers
    function isSignedIn() { return request.auth != null; }
    
    // Helper to check if user is a member of a group
    function isMember(groupId) {
      return groupId != null && 
             exists(/databases/$(database)/documents/groups/$(groupId)) && 
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /{path=**}/invitations/{inviteId} {
      allow read: if isSignedIn() && resource.data.email == request.auth.token.email;
    }

    // 2. Groups
    match /groups/{groupId} {
      // Allow listing if the user is a member (forces the array-contains user.uid query)
      allow list: if isSignedIn() && request.auth.uid in resource.data.members;
      
      // Allow get for members and owners
      allow get: if isSignedIn() && (request.auth.uid in resource.data.members || resource.data.ownerId == request.auth.uid);
      
      // Allow update
      allow update: if isSignedIn() && (
        // Case 1: Member joining (adding self to members list)
        (
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() + 1 &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.ownerId == resource.data.ownerId
        ) ||
        // Case 2: Owner modifying group (name or member removal)
        (
          resource.data.ownerId == request.auth.uid &&
          request.resource.data.ownerId == resource.data.ownerId
        ) ||
        // Case 3: Member leaving (removing self)
        (
          request.auth.uid in resource.data.members &&
          !(request.auth.uid in request.resource.data.members) &&
          request.resource.data.members.size() == resource.data.members.size() - 1 &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.ownerId == resource.data.ownerId
        )
      );

      // Allow create if ownerId matches
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Allow delete if owner matches
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Invitations subcollection
      match /invitations/{inviteId} {
        allow list: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid ||
          resource.data.email == request.auth.token.email
        );
        allow get: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid ||
          resource.data.email == request.auth.token.email
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid
        ) && (
          request.resource.data.status == 'pending' &&
          request.resource.data.invitedBy == request.auth.uid
        );
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid ||
          (resource != null && resource.data.email == request.auth.token.email)
        );
        allow delete: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid
        );
      }
    }

    // 3. User & Group Data (Invoices, Incomes, Expenses, Categories)
    match /invoices/{docId} {
      // For list queries, we'll allow if user is signed in. 
      // Security is enforced by the groupId filter in the query.
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.groupId == request.auth.uid || isMember(resource.data.groupId));
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }
    
    match /incomes/{docId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.groupId == request.auth.uid || isMember(resource.data.groupId));
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }

    match /expenses/{docId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.groupId == request.auth.uid || isMember(resource.data.groupId));
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }
    
    match /clients/{docId} {
      allow list, get: if isSignedIn();
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }
    
    match /deals/{docId} {
      allow list, get: if isSignedIn();
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }

    match /documents/{docId} {
      allow list, get: if isSignedIn();
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }

    match /categories/{docId} {
      allow list, get: if isSignedIn();
      allow create, update: if isSignedIn() && (
        (request.resource.data.groupId == request.auth.uid) || 
        isMember(request.resource.data.groupId)
      );
      allow delete: if isSignedIn() && (
        (resource.data.groupId == request.auth.uid) || 
        isMember(resource.data.groupId)
      );
    }

    match /activities/{activityId} {
      allow list, get: if isSignedIn() && (resource.data.groupId == request.auth.uid || isMember(resource.data.groupId));
      allow create: if isSignedIn() && (request.resource.data.groupId == request.auth.uid || isMember(request.resource.data.groupId));
      allow update, delete: if false;
    }
  }
}
